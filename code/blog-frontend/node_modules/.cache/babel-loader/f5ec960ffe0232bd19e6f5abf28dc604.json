ottom","containLabel","xAxis","boundaryGap","day","yAxis","smooth","positive","negative","sortedData","sort","a","b","value","axisPointer","graphic","LinearGradient","offset","label","show","position"],"sources":["src/views/cms/sentiment/index.vue"],"sourcesContent":["<template>\r\n    <div class=\"app-container\" style=\"background-color: #f0f2f5; padding: 20px; min-height: calc(100vh - 84px);\">\r\n      <!-- 顶部数据概览 -->\r\n      <el-row :gutter=\"20\">\r\n        <el-col :span=\"12\">\r\n          <el-card shadow=\"always\" :body-style=\"{ padding: '20px' }\">\r\n            <div slot=\"header\" class=\"clearfix\">\r\n              <span style=\"font-weight: bold\"><i class=\"el-icon-pie-chart\"></i> 评论情感分布占比</span>\r\n            </div>\r\n            <div ref=\"pieChart\" style=\"height: 350px;\"></div>\r\n          </el-card>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-card shadow=\"always\" :body-style=\"{ padding: '20px' }\">\r\n            <div slot=\"header\" class=\"clearfix\">\r\n              <span style=\"font-weight: bold\"><i class=\"el-icon-trend-charts\"></i> 近一周情感变化趋势</span>\r\n            </div>\r\n            <div ref=\"lineChart\" style=\"height: 350px;\"></div>\r\n          </el-card>\r\n        </el-col>\r\n      </el-row>\r\n  \r\n      <!-- 底部关键词分析 -->\r\n      <el-row :gutter=\"20\" style=\"margin-top: 20px;\">\r\n        <el-col :span=\"24\">\r\n          <el-card shadow=\"always\">\r\n            <div slot=\"header\" class=\"clearfix\">\r\n              <span style=\"font-weight: bold\"><i class=\"el-icon-warning-outline\"></i> 负面评论关键词 TOP10 (AI 实时提取)</span>\r\n            </div>\r\n            <div v-show=\"!noData\" ref=\"barChart\" style=\"height: 400px;\"></div>\r\n            <div v-show=\"noData\" style=\"height: 400px; display: flex; justify-content: center; align-items: center; color: #909399;\">\r\n              <el-empty description=\"暂无负面评论数据，继续保持哦！\"></el-empty>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n      </el-row>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  import * as echarts from 'echarts';\r\n  import { getSentimentDashboard } from \"@/api/cms/sentiment\";\r\n  \r\n  export default {\r\n    name: \"Sentiment\",\r\n    data() {\r\n      return {\r\n        noData: false,\r\n        myCharts: {\r\n          pie: null,\r\n          line: null,\r\n          bar: null\r\n        }\r\n      };\r\n    },\r\n    mounted() {\r\n      this.initCharts();\r\n      this.handleData();\r\n      // 响应式处理\r\n      window.addEventListener(\"resize\", this.resizeCharts);\r\n    },\r\n    beforeDestroy() {\r\n      window.removeEventListener(\"resize\", this.resizeCharts);\r\n    },\r\n    methods: {\r\n      initCharts() {\r\n        this.myCharts.pie = echarts.init(this.$refs.pieChart);\r\n        this.myCharts.line = echarts.init(this.$refs.lineChart);\r\n        this.myCharts.bar = echarts.init(this.$refs.barChart);\r\n      },\r\n      resizeCharts() {\r\n        this.myCharts.pie && this.myCharts.pie.resize();\r\n        this.myCharts.line && this.myCharts.line.resize();\r\n        this.myCharts.bar && this.myCharts.bar.resize();\r\n      },\r\n      handleData() {\r\n        getSentimentDashboard().then(res => {\r\n          const { pieData, trendData, cloudData } = res.data;\r\n          \r\n          this.renderPie(pieData);\r\n          this.renderLine(trendData);\r\n          \r\n          if (cloudData && cloudData.length > 0) {\r\n            this.noData = false;\r\n            this.renderBar(cloudData);\r\n          } else {\r\n            this.noData = true;\r\n          }\r\n        });\r\n      },\r\n      renderPie(data) {\r\n        this.myCharts.pie.setOption({\r\n          tooltip: { trigger: 'item', formatter: '{a} <br/>{b} : {c} ({d}%)' },\r\n          legend: { orient: 'vertical', left: 'left', data: data.map(i => i.name) },\r\n          color: ['#91cc75', '#fac858', '#ee6666', '#73c0de'], // 绿、黄、红\r\n          series: [{\r\n            name: '情感倾向',\r\n            type: 'pie',\r\n            radius: '65%',\r\n            center: ['50%', '50%'],\r\n            data: data,\r\n            emphasis: {\r\n              itemStyle: { shadowBlur: 10, shadowOffsetX: 0, shadowColor: 'rgba(0, 0, 0, 0.5)' }\r\n            }\r\n          }]\r\n        });\r\n      },\r\n      renderLine(data) {\r\n        this.myCharts.line.setOption({\r\n          tooltip: { trigger: 'axis' },\r\n          legend: { data: ['正面', '负面'] },\r\n          grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },\r\n          xAxis: { type: 'category', boundaryGap: false, data: data.map(i => i.day) },\r\n          yAxis: { type: 'value' },\r\n          series: [\r\n            { name: '正面', type: 'line', smooth: true, color: '#91cc75', data: data.map(i => i.positive) },\r\n            { name: '负面', type: 'line', smooth: true, color: '#ee6666', data: data.map(i => i.negative) }\r\n          ]\r\n        });\r\n      },\r\n      renderBar(data) {\r\n        // 这里的词云用横向柱状图展示，更符合后台管理系统的严肃风格\r\n        const sortedData = data.sort((a, b) => a.value - b.value);\r\n        this.myCharts.bar.setOption({\r\n          tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },\r\n          grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },\r\n          xAxis: { type: 'value' },\r\n          yAxis: { type: 'category', data: sortedData.map(i => i.name) },\r\n          series: [{\r\n            name: '出现频次',\r\n            type: 'bar',\r\n            data: sortedData.map(i => i.value),\r\n            itemStyle: {\r\n              color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [\r\n                { offset: 0, color: '#ff9a9e' },\r\n                { offset: 1, color: '#fecfef' }\r\n              ])\r\n            },\r\n            label: { show: true, position: 'right' }\r\n          }]\r\n        });\r\n      }\r\n    }\r\n  };\r\n  </script>\r\n  \r\n  <style scoped>\r\n  .clearfix:before,\r\n  .clearfix:after {\r\n    display: table;\r\n    content: \"\";\r\n  }\r\n  .clearfix:after {\r\n    clear: both\r\n  }\r\n  </style>"],"mappings":";;;;;;;;;;;;;AAwCA,IAAAA,OAAA,GAAAC,uBAAA,CAAAC,OAAA;AACA,IAAAC,UAAA,GAAAD,OAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;iCAEA;EACAE,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,MAAA;MACAC,QAAA;QACAC,GAAA;QACAC,IAAA;QACAC,GAAA;MACA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,UAAA;IACA,KAAAC,UAAA;IACA;IACAC,MAAA,CAAAC,gBAAA,gBAAAC,YAAA;EACA;EACAC,aAAA,WAAAA,cAAA;IACAH,MAAA,CAAAI,mBAAA,gBAAAF,YAAA;EACA;EACAG,OAAA;IACAP,UAAA,WAAAA,WAAA;MACA,KAAAL,QAAA,CAAAC,GAAA,GAAAR,OAAA,CAAAoB,IAAA,MAAAC,KAAA,CAAAC,QAAA;MACA,KAAAf,QAAA,CAAAE,IAAA,GAAAT,OAAA,CAAAoB,IAAA,MAAAC,KAAA,CAAAE,SAAA;MACA,KAAAhB,QAAA,CAAAG,GAAA,GAAAV,OAAA,CAAAoB,IAAA,MAAAC,KAAA,CAAAG,QAAA;IACA;IACAR,YAAA,WAAAA,aAAA;MACA,KAAAT,QAAA,CAAAC,GAAA,SAAAD,QAAA,CAAAC,GAAA,CAAAiB,MAAA;MACA,KAAAlB,QAAA,CAAAE,IAAA,SAAAF,QAAA,CAAAE,IAAA,CAAAgB,MAAA;MACA,KAAAlB,QAAA,CAAAG,GAAA,SAAAH,QAAA,CAAAG,GAAA,CAAAe,MAAA;IACA;IACAZ,UAAA,WAAAA,WAAA;MAAA,IAAAa,KAAA;MACA,IAAAC,gCAAA,IAAAC,IAAA,WAAAC,GAAA;QACA,IAAAC,SAAA,GAAAD,GAAA,CAAAxB,IAAA;UAAA0B,OAAA,GAAAD,SAAA,CAAAC,OAAA;UAAAC,SAAA,GAAAF,SAAA,CAAAE,SAAA;UAAAC,SAAA,GAAAH,SAAA,CAAAG,SAAA;QAEAP,KAAA,CAAAQ,SAAA,CAAAH,OAAA;QACAL,KAAA,CAAAS,UAAA,CAAAH,SAAA;QAEA,IAAAC,SAAA,IAAAA,SAAA,CAAAG,MAAA;UACAV,KAAA,CAAApB,MAAA;UACAoB,KAAA,CAAAW,SAAA,CAAAJ,SAAA;QACA;UACAP,KAAA,CAAApB,MAAA;QACA;MACA;IACA;IACA4B,SAAA,WAAAA,UAAA7B,IAAA;MACA,KAAAE,QAAA,CAAAC,GAAA,CAAA8B,SAAA;QACAC,OAAA;UAAAC,OAAA;UAAAC,SAAA;QAAA;QACAC,MAAA;UAAAC,MAAA;UAAAC,IAAA;UAAAvC,IAAA,EAAAA,IAAA,CAAAwC,GAAA,WAAAC,CAAA;YAAA,OAAAA,CAAA,CAAA1C,IAAA;UAAA;QAAA;QACA2C,KAAA;QAAA;QACAC,MAAA;UACA5C,IAAA;UACA6C,IAAA;UACAC,MAAA;UACAC,MAAA;UACA9C,IAAA,EAAAA,IAAA;UACA+C,QAAA;YACAC,SAAA;cAAAC,UAAA;cAAAC,aAAA;cAAAC,WAAA;YAAA;UACA;QACA;MACA;IACA;IACArB,UAAA,WAAAA,WAAA9B,IAAA;MACA,KAAAE,QAAA,CAAAE,IAAA,CAAA6B,SAAA;QACAC,OAAA;UAAAC,OAAA;QAAA;QACAE,MAAA;UAAArC,IAAA;QAAA;QACAoD,IAAA;UAAAb,IAAA;UAAAc