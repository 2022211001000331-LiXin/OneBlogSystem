     }, 100);\n        });\n      },\n      // 文件下载处理\n      handleDownload(row) {\n        var name = row.fileOriginName;\n        var url = row.filePath;\n        var suffix = url.substring(url.lastIndexOf(\".\"), url.length);\n        const a = document.createElement('a')\n        a.setAttribute('download', name)\n        a.setAttribute('target', '_blank')\n        a.setAttribute('href', process.env.VUE_APP_BASE_API + url)\n        a.click()\n      },\n      setFormContent(){\n        this.form.content = this.$refs.CherryMarkdown.getCherryHtml()\n      },\n    }\n  };\n</script>\n"],"mappings":";;;;;;;;;;;;AAyJA,IAAAA,KAAA,GAAAC,OAAA;AAOA,IAAAC,SAAA,GAAAD,OAAA;AAGA,IAAAE,aAAA,GAAAF,OAAA;AAKA,IAAAG,UAAA,GAAAH,OAAA;AAGA,IAAAI,eAAA,GAAAC,sBAAA,CAAAL,OAAA;AACA,IAAAM,QAAA,GAAAD,sBAAA,CAAAL,OAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;iCAEA;EACAO,IAAA;EACAC,KAAA;EACAC,UAAA;IACAC,cAAA,EAAAA,uBAAA;IACAC,OAAA,EAAAA;EACA;EACAC,IAAA,WAAAA,KAAA;IACA;MACA;MACAC,OAAA;MACA;MACAC,GAAA;MACA;MACAC,MAAA;MACA;MACAC,QAAA;MACA;MACAC,UAAA;MACA;MACAC,KAAA;MACA;MACAC,QAAA;MACA;MACAC,YAAA;MACA;MACAC,KAAA;MACA;MACAC,IAAA;MACAC,YAAA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,QAAA;QACAL,KAAA;QACAM,IAAA;QACAC,OAAA;QACAC,GAAA;QACAC,KAAA;QACAC,MAAA;QACAC,QAAA;MACA;MACA;MACAC,IAAA;MACAJ,GAAA;MACA;MACAK,KAAA;QACAb,KAAA;UACAc,QAAA;UACAC,OAAA;UACAC,OAAA;QACA;QACAV,IAAA;UACAQ,QAAA;UACAC,OAAA;UACAC,OAAA;QACA;MACA;MACAC,OAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,OAAA;EACA;EACAC,OAAA;IACA,eACAD,OAAA,WAAAA,QAAA;MAAA,IAAAE,KAAA;MACA,KAAA7B,OAAA;MACA,IAAA8B,cAAA,OAAAnB,WAAA,EAAAoB,IAAA,WAAAC,QAAA;QACAH,KAAA,CAAAvB,QAAA,GAAA0B,QAAA,CAAAC,IAAA;QACAJ,KAAA,CAAAxB,KAAA,GAAA2B,QAAA,CAAA3B,KAAA;QACAwB,KAAA,CAAA7B,OAAA;MACA;IACA;IACA;IACAkC,MAAA,WAAAA,OAAA;MAAA,IAAAC,MAAA;MACA,KAAAC,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAxB,IAAA;MACA,GAAAiB,IAAA;QACA,IAAAQ,OAAA,GAAAJ,MAAA,CAAAV,OAAA;QACA,IAAAc,OAAA,CAAAC,MAAA;UACA